# ===========================================
# ZAK TRANSPORTATION SAAS - ENVIRONMENT CONFIG
# ===========================================
# IMPORTANT: Never commit .env to git!
# Copy this to .env and fill in your values
# ===========================================

# Server
NODE_ENV=development
PORT=3000

# MongoDB Connection
# Get this from MongoDB Atlas dashboard
MONGODB_URI=mongodb+srv://zakadmin:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/zak-transport?retryWrites=true&w=majority

# JWT Secret (generate a random string - at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Super Admin Setup (your master account)
SUPER_ADMIN_EMAIL=rich@exoffender.org
SUPER_ADMIN_PASSWORD=change-this-to-a-strong-password

# App URL (update when deployed)
APP_URL=http://localhost:3000

# Twilio SMS Integration (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
