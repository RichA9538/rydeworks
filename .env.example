# ===========================================
# ZAK TRANSPORTATION SAAS - ENVIRONMENT CONFIG
# ===========================================
# IMPORTANT: Never commit .env to git!
# Copy this to .env and fill in your values
# ===========================================

# Server
NODE_ENV=development
PORT=3000

# MongoDB Connection
# Get this from MongoDB Atlas dashboard
MONGODB_URI=mongodb+srv://zakadmin:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/zak-transport?retryWrites=true&w=majority

# JWT Secret (generate a random string - at least 32 characters)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Super Admin Setup (your master account)
SUPER_ADMIN_EMAIL=rich@exoffender.org
SUPER_ADMIN_PASSWORD=change-this-to-a-strong-password

# App URL (update when deployed)
APP_URL=http://localhost:3000

# Stripe Payment Integration
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Twilio SMS Integration
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...

# Dispatch phone number — receives SMS when a driver marks themselves unavailable
# Use your main dispatch line (e.g. the PERC office number)
DISPATCH_PHONE=+17273131241

# Mapbox (live van tracking on dispatch map)
# Get a token at https://account.mapbox.com
MAPBOX_TOKEN=pk.eyJ1...
